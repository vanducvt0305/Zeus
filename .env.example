# Copy to .env and adjust. All values have defaults that work out of the box
# with `docker compose up -d` and the offline "hash" embedder.

# --- Qdrant (vector store) ---
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=mcps

# --- Embedder ---
# "hash"  : offline, zero-setup, lexical only (default; good for a first run)
# "openai": any OpenAI-compatible /embeddings endpoint (real semantic quality)
EMBEDDER=hash

# Only used when EMBEDDER=openai. The SAME values must be set for both the
# indexer and the server. Examples:
#   OpenAI : EMBED_BASE_URL=https://api.openai.com/v1   EMBED_MODEL=text-embedding-3-small  EMBED_DIM=1536
#   Voyage : EMBED_BASE_URL=https://api.voyageai.com/v1 EMBED_MODEL=voyage-3                EMBED_DIM=1024
#   Ollama : EMBED_BASE_URL=http://localhost:11434/v1   EMBED_MODEL=nomic-embed-text        EMBED_DIM=768
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=
EMBED_MODEL=nomic-embed-text
EMBED_DIM=256

# --- Source ---
# Leave empty to use the official registry (https://registry.modelcontextprotocol.io).
REGISTRY_URL=
