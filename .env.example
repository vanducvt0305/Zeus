# Copy to .env and adjust. All values have defaults that work out of the box
# with `docker compose up -d` and the offline "hash" embedder.

# --- Qdrant (vector store) ---
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=mcps

# --- Embedder ---
# "hash"  : offline, zero-setup, lexical only (default; good for a first run)
# "openai": any OpenAI-compatible /embeddings endpoint (real semantic quality)
EMBEDDER=hash

# Only used when EMBEDDER=openai. The SAME values must be set for both the
# indexer and the server. Examples:
#   OpenAI : EMBED_BASE_URL=https://api.openai.com/v1   EMBED_MODEL=text-embedding-3-small  EMBED_DIM=1536
#   Voyage : EMBED_BASE_URL=https://api.voyageai.com/v1 EMBED_MODEL=voyage-3                EMBED_DIM=1024
#   Ollama : EMBED_BASE_URL=http://localhost:11434/v1   EMBED_MODEL=nomic-embed-text        EMBED_DIM=768
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=
EMBED_MODEL=nomic-embed-text
EMBED_DIM=256

# --- Source (what the indexer crawls) ---
# "registry" (default): the official MCP registry
# "github"            : search GitHub for MCP repos (set GITHUB_TOKEN to raise limits)
# "file"              : a local JSON catalog (set SOURCE_FILE)
# May be a comma-separated list (e.g. "registry,github"); duplicates across
# sources are merged by identity resolution.
SOURCE=registry
GITHUB_TOKEN=
# Comma-separated GitHub search queries; empty uses sensible topic defaults.
GITHUB_QUERIES=
SOURCE_FILE=

# --- Tool extraction ---
# When true, the indexer connects to each server's REMOTE endpoint and calls
# tools/list to recover its real tools (the registry does not list them).
# Package-based (stdio) servers are never executed. Off by default: it is slow
# and many public servers require auth.
EXTRACT_TOOLS=false
EXTRACT_CONCURRENCY=8
EXTRACT_TIMEOUT=20
# Auth for reaching servers that gate tools/list. EXTRACT_AUTH_TOKEN is a global
# bearer token applied to every probe. EXTRACT_CREDENTIALS points to a JSON file
# with per-server headers (keyed by MCP id, host, or "*.host" wildcard), e.g.:
#   { "io.github.acme/search": {"Authorization": "Bearer ..."},
#     "api.example.com":       {"X-API-Key": "..."},
#     "*.corp.internal":       {"Authorization": "Bearer ..."} }
EXTRACT_AUTH_TOKEN=
EXTRACT_CREDENTIALS=

# --- Enricher (capability cards + synthetic queries) ---
# "heuristic": offline, derives tasks/queries from tool names (default)
# "llm"      : high quality, rewrites each MCP via an LLM (needs LLM_API_KEY)
# "none"     : no enrichment (baseline for evaluation)
ENRICHER=heuristic

# Only used when ENRICHER=llm. "anthropic" (Claude Messages API) or "openai"
# (any OpenAI-compatible /chat/completions, including a local Ollama).
LLM_PROVIDER=anthropic
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5

# --- Retrieval ---
# Hybrid search fuses dense (semantic) and sparse (keyword) retrieval with RRF.
# Sparse vectors are always stored at index time, so this can be toggled at
# query time without re-indexing.
HYBRID=true

# Reranker re-orders the first-stage shortlist:
# "lexical": offline cross-encoder-style term-coverage scorer (default)
# "llm"    : LLM judges the shortlist (needs LLM_API_KEY; reuses the LLM_* vars)
# "none"   : no reranking (baseline)
RERANKER=lexical
# How many first-stage candidates to rerank before truncating to top-k.
RERANK_POOL=30

# --- Source ---
# Leave empty to use the official registry (https://registry.modelcontextprotocol.io).
REGISTRY_URL=
